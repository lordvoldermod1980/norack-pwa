# Local development only (vite dev server). Copy to .env.local and fill in.
# The app talks straight to the cloud backend (Hono on CF Workers / Deno) with a Bearer token obtained at
# login — there are no build-time secrets. These vars only tweak defaults.

# Default backend on first load: cf (Cloudflare, primary) | deno (backup). Staff can switch in-app; their
# choice is stored per-origin in localStorage and overrides this. CF Pages build defaults cf, GitHub Pages
# build defaults deno (set in CI) — this is only for local dev.
VITE_API_BACKEND=cf
