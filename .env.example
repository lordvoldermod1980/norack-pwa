# Local development only (vite dev server). Copy to .env.local and fill in.
# In production these are NOT used — the Cloudflare Pages Functions inject the
# token server-side from Pages secrets (N8N_TOKEN / SSE_TOKEN).

# Authorization header value for the n8n webhooks (dev proxy /webhook -> n8n)
VITE_NORACK_AUTH=

# Optional: override the dev SSE endpoint (defaults to http://localhost:3055/events)
# VITE_SSE_URL=http://localhost:3055/events
